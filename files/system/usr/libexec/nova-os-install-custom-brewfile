#!/usr/bin/env bash
set -oue pipefail

# Run as the default user since brew bundle needs user context
BREWFILE="/usr/share/ublue-os/homebrew/custom.Brewfile"
MARKER="/var/lib/misc/nova-os-brewfile-ran"

if [[ -f "$MARKER" ]]; then
    echo "nova-os: Custom Brewfile already applied, skipping."
    exit 0
fi

if [[ ! -f /home/linuxbrew/.linuxbrew/bin/brew ]]; then
    echo "nova-os: Homebrew not ready yet, will retry on next boot."
    exit 1
fi

echo "nova-os: Installing custom Brewfile packages..."
sudo -u "$(id -un 1000)" HOMEBREW_PREFIX=/home/linuxbrew/.linuxbrew PATH="/home/linuxbrew/.linuxbrew/bin:$PATH" brew bundle --file="$BREWFILE"

mkdir -p "$(dirname "$MARKER")"
touch "$MARKER"